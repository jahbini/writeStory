{
  "lepa_version": "0.2-draft",
  "name": "LEPA Tarot Translation Framework",
  "definition": {
    "LEPA": "Logos / Ethos / Pathos / Anima",
    "purpose": "Translate Tarot-like symbolic structure into a non-Tarot diagnostic narrative system.",
    "translation_rule": "Each symbolic pattern becomes movement, imbalance, correction.",
    "public_rule": "Do not use Tarot language in generated public-facing output unless explicitly requested.",
    "core_fields": [
      "movement",
      "imbalance",
      "correction"
    ]
  },
  "energy_model": {
    "logos": {
      "domain": "thought, interpretation, meaning, signal",
      "motion_failure": "noise, over-framing, argument replacing truth",
      "suit_shadow": "Swords"
    },
    "ethos": {
      "domain": "conduct, structure, duty, material action",
      "motion_failure": "grabbing, stalling, rigid repetition",
      "suit_shadow": "Pentacles"
    },
    "pathos": {
      "domain": "emotion, desire, reaction, attraction",
      "motion_failure": "spike, contagion, capture, overreaction",
      "suit_shadow": "Cups"
    },
    "anima": {
      "domain": "life-force, vitality, axis, coherence",
      "motion_failure": "drag, depletion, wobble, collapse",
      "suit_shadow": "Wands"
    }
  },
  "dynamical_model": {
    "center": "self",
    "orbiting_bodies": [
      "logos",
      "ethos",
      "pathos"
    ],
    "axis": "anima",
    "constraint": "Logos, Ethos, and Pathos remain bounded near the self, like coupled bodies held at fixed distance.",
    "eigenvector_note": "Anima may be treated as the dominant direction or coherence mode emerging from Logos/Ethos/Pathos interaction.",
    "one_line": "Logos, Ethos, and Pathos move around the self; Anima determines whether they move together or fall apart."
  },
  "voice_policy": {
    "tommy": {
      "allow_mensch_labels": true,
      "tone": "sharp, mocking, reactive"
    },
    "jim": {
      "allow_mensch_labels": false,
      "tone": "grounded, human, observational"
    },
    "southwick": {
      "allow_mensch_labels": false,
      "tone": "precise, mechanism-level"
    },
    "roger": {
      "allow_mensch_labels": false,
      "tone": "indirect, drifting, incomplete"
    }
  },
